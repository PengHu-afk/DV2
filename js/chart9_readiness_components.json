{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Stacked component chart showing how the road-trip readiness score is built from weighted facility-support features.",
  "title": {
    "text": "What makes a state road-trip ready?",
    "subtitle": "States are sorted from highest to lowest total readiness score. The black dot marks the final weighted score.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "width": 760,
  "height": 390,
  "data": {
    "url": "data_clean/readiness_components_long.csv"
  },
  "transform": [
    {
      "filter": "datum.State != null && datum.State != '' && datum.State != 'NA'"
    },
    {
      "filter": "datum.State_Full != null && datum.State_Full != '' && datum.State_Full != 'NA'"
    },
    {
      "calculate": "datum.Component == 'Accessible' ? 'Accessible access' : datum.Component == '24-hour' ? '24-hour access' : datum.Component == 'Parking' ? 'Parking' : datum.Component == 'Baby change' ? 'Baby-change facilities' : datum.Component == 'Shower' ? 'Showers' : datum.Component",
      "as": "Component_Clean"
    },
    {
      "calculate": "datum.Weighted_Value * 100",
      "as": "Weighted_Percent"
    },
    {
      "calculate": "datum.Roadtrip_Readiness_Score * 100",
      "as": "Score_Percent"
    },
    {
      "calculate": "datum.Rate * 100",
      "as": "Rate_Percent"
    },
    {
      "calculate": "format(datum.Weighted_Percent, '.1f') + ' pts'",
      "as": "Weighted_Label"
    },
    {
      "calculate": "format(datum.Score_Percent, '.1f') + '%'",
      "as": "Score_Label"
    },
    {
      "calculate": "format(datum.Rate_Percent, '.1f') + '%'",
      "as": "Rate_Label"
    },
    {
      "calculate": "format(datum.Weight, '.0%')",
      "as": "Weight_Label"
    },
    {
      "joinaggregate": [
        {
          "op": "max",
          "field": "Score_Percent",
          "as": "State_Score"
        }
      ],
      "groupby": [
        "State"
      ]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 2
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "State_Score",
            "order": "descending"
          },
          "axis": {
            "labelFontSize": 12
          }
        },
        "x": {
          "field": "Weighted_Percent",
          "type": "quantitative",
          "title": "Weighted contribution to readiness score (percentage points)",
          "stack": "zero",
          "axis": {
            "labelFontSize": 11,
            "titleFontSize": 12,
            "grid": true
          }
        },
        "color": {
          "field": "Component_Clean",
          "type": "nominal",
          "title": "Score component and weight",
          "sort": {
            "field": "Component_Order",
            "order": "ascending"
          },
          "scale": {
            "domain": [
              "Accessible access",
              "24-hour access",
              "Parking",
              "Baby-change facilities",
              "Showers"
            ],
            "range": [
              "#4f6f7f",
              "#6b4f3f",
              "#b77945",
              "#d9a65f",
              "#5f7f58"
            ]
          },
          "legend": {
            "orient": "top",
            "direction": "horizontal",
            "labelExpr": "datum.label == 'Accessible access' ? 'Accessible access, 30%' : datum.label == '24-hour access' ? '24-hour access, 25%' : datum.label == 'Parking' ? 'Parking, 20%' : datum.label == 'Baby-change facilities' ? 'Baby change, 15%' : datum.label == 'Showers' ? 'Showers, 10%' : datum.label"
          }
        },
        "order": {
          "field": "Component_Order",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "State_Full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Component_Clean",
            "type": "nominal",
            "title": "Component"
          },
          {
            "field": "Rate_Label",
            "type": "nominal",
            "title": "Original facility rate"
          },
          {
            "field": "Weight_Label",
            "type": "nominal",
            "title": "Index weight"
          },
          {
            "field": "Weighted_Label",
            "type": "nominal",
            "title": "Weighted contribution"
          },
          {
            "field": "Score_Label",
            "type": "nominal",
            "title": "Total readiness score"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "max",
              "field": "Score_Percent",
              "as": "Total_Score"
            },
            {
              "op": "max",
              "field": "State_Score",
              "as": "State_Score"
            }
          ],
          "groupby": [
            "State"
          ]
        },
        {
          "calculate": "format(datum.Total_Score, '.1f') + '%'",
          "as": "Total_Score_Label"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 120,
        "color": "#2b2118",
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal",
          "sort": {
            "field": "State_Score",
            "order": "descending"
          }
        },
        "x": {
          "field": "Total_Score",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "State",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Total_Score",
            "type": "quantitative",
            "title": "Total readiness score",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "max",
              "field": "Score_Percent",
              "as": "Total_Score"
            },
            {
              "op": "max",
              "field": "State_Score",
              "as": "State_Score"
            }
          ],
          "groupby": [
            "State"
          ]
        },
        {
          "calculate": "format(datum.Total_Score, '.1f') + '%'",
          "as": "Total_Score_Label"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#2b2118"
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal",
          "sort": {
            "field": "State_Score",
            "order": "descending"
          }
        },
        "x": {
          "field": "Total_Score",
          "type": "quantitative"
        },
        "text": {
          "field": "Total_Score_Label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}