{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Small multiple maps showing public toilets that support different road-trip traveller needs, manually arranged as a 2x2 grid.",
  "title": {
    "text": "Different road-trip needs create different toilet maps",
    "subtitle": "Each panel filters the toilet network by one traveller need.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "vconcat": [
    {
      "hconcat": [
        {
          "title": {
            "text": "24-hour access",
            "fontSize": 14,
            "fontWeight": "bold",
            "anchor": "start"
          },
          "width": 300,
          "height": 220,
          "projection": {
            "type": "mercator"
          },
          "layer": [
            {
              "data": {
                "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
                "format": {
                  "type": "geojson"
                }
              },
              "mark": {
                "type": "geoshape",
                "fill": "#f8f5f0",
                "stroke": "#d9d2c8",
                "strokeWidth": 0.8
              }
            },
            {
              "data": {
                "url": "data_clean/toilet_need_map_long.csv"
              },
              "transform": [
                {
                  "filter": "datum.Traveller_Need == '24-hour access'"
                },
                {
                  "filter": "isValid(datum.Longitude) && isValid(datum.Latitude)"
                },
                {
                  "filter": "datum.Longitude >= 112 && datum.Longitude <= 154 && datum.Latitude >= -44 && datum.Latitude <= -10"
                }
              ],
              "mark": {
                "type": "circle",
                "size": 6,
                "opacity": 0.22,
                "color": "#6b4f3f"
              },
              "encoding": {
                "longitude": {
                  "field": "Longitude",
                  "type": "quantitative"
                },
                "latitude": {
                  "field": "Latitude",
                  "type": "quantitative"
                },
                "tooltip": [
                  {
                    "field": "Name",
                    "type": "nominal",
                    "title": "Toilet name"
                  },
                  {
                    "field": "Town",
                    "type": "nominal",
                    "title": "Town"
                  },
                  {
                    "field": "State",
                    "type": "nominal",
                    "title": "State"
                  },
                  {
                    "field": "FacilityType",
                    "type": "nominal",
                    "title": "Facility type"
                  }
                ]
              }
            },
            {
              "data": {
                "url": "data_clean/toilet_need_map_long.csv"
              },
              "transform": [
                {
                  "filter": "datum.Traveller_Need == '24-hour access'"
                },
                {
                  "aggregate": [
                    {
                      "op": "count",
                      "field": "FacilityID",
                      "as": "Need_Count"
                    }
                  ]
                },
                {
                  "calculate": "format(datum.Need_Count, ',') + ' toilets'",
                  "as": "Need_Count_Label"
                },
                {
                  "calculate": "113.5",
                  "as": "Note_Longitude"
                },
                {
                  "calculate": "-12",
                  "as": "Note_Latitude"
                }
              ],
              "mark": {
                "type": "text",
                "align": "left",
                "baseline": "top",
                "fontSize": 12,
                "fontWeight": "bold",
                "color": "#2b2118",
                "stroke": "white",
                "strokeWidth": 4
              },
              "encoding": {
                "longitude": {
                  "field": "Note_Longitude",
                  "type": "quantitative"
                },
                "latitude": {
                  "field": "Note_Latitude",
                  "type": "quantitative"
                },
                "text": {
                  "field": "Need_Count_Label",
                  "type": "nominal"
                }
              }
            }
          ]
        },
        {
          "title": {
            "text": "Accessible access",
