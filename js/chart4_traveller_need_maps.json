{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Small multiple maps showing public toilets that support different road-trip traveller needs, arranged in a 2x2 grid with a consistent Australia base map.",
  "title": {
    "text": "Different road-trip needs create different toilet maps",
    "subtitle": "Each panel filters the toilet network by one traveller need and shows how support changes across Australia.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "data": {
    "url": "data_clean/toilet_need_map_long.csv"
  },
  "facet": {
    "field": "Traveller_Need",
    "type": "nominal",
    "columns": 2,
    "sort": [
      "24-hour access",
      "Accessible access",
      "Family support",
      "Caravan support"
    ],
    "header": {
      "title": null,
      "labelFontSize": 14,
      "labelFontWeight": "bold",
      "labelColor": "#2b2118"
    }
  },
  "spec": {
    "width": 300,
    "height": 220,
    "projection": {
      "type": "mercator"
    },
    "layer": [
      {
        "data": {
          "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
          "format": {
            "type": "geojson"
          }
        },
        "mark": {
          "type": "geoshape",
          "fill": "#f8f5f0",
          "stroke": "#d9d2c8",
          "strokeWidth": 0.8
        }
      },
      {
        "transform": [
          {
            "filter": "isValid(datum.Longitude) && isValid(datum.Latitude)"
          },
          {
            "filter": "datum.Longitude >= 112 && datum.Longitude <= 154 && datum.Latitude >= -44 && datum.Latitude <= -10"
          }
        ],
        "mark": {
          "type": "circle",
          "size": 7,
          "opacity": 0.22
        },
        "encoding": {
          "longitude": {
            "field": "Longitude",
            "type": "quantitative"
          },
          "latitude": {
            "field": "Latitude",
            "type": "quantitative"
          },
          "color": {
            "field": "Traveller_Need",
            "type": "nominal",
            "legend": null,
            "scale": {
              "domain": [
                "24-hour access",
                "Accessible access",
                "Family support",
                "Caravan support"
              ],
              "range": [
                "#6b4f3f",
                "#4f6f7f",
                "#b77945",
                "#5f7f58"
              ]
            }
          },
          "tooltip": [
            {
              "field": "Name",
              "type": "nominal",
              "title": "Toilet name"
            },
            {
              "field": "Town",
              "type": "nominal",
              "title": "Town"
            },
            {
              "field": "State",
              "type": "nominal",
              "title": "State"
            },
            {
              "field": "FacilityType",
              "type": "nominal",
              "title": "Facility type"
            },
            {
              "field": "Traveller_Need",
              "type": "nominal",
              "title": "Traveller need"
            }
          ]
        }
      },
      {
        "transform": [
          {
            "aggregate": [
              {
                "op": "count",
                "field": "FacilityID",
                "as": "Need_Count"
              }
            ],
            "groupby": [
              "Traveller_Need"
            ]
          },
          {
            "calculate": "format(datum.Need_Count, ',') + ' toilets'",
            "as": "Need_Count_Label"
          },
          {
            "calculate": "113.4",
            "as": "Note_Longitude"
          },
          {
            "calculate": "-11.8",
            "as": "Note_Latitude"
          }
        ],
        "mark": {
          "type": "text",
          "align": "left",
          "baseline": "top",
          "fontSize": 12,
          "fontWeight": "bold",
          "color": "#2b2118",
          "stroke": "white",
          "strokeWidth": 4
        },
        "encoding": {
          "longitude": {
            "field": "Note_Longitude",
            "type": "quantitative"
          },
          "latitude": {
            "field": "Note_Latitude",
            "type": "quantitative"
          },
          "text": {
            "field": "Need_Count_Label",
            "type": "nominal"
          }
        }
      }
    ]
  },
  "resolve": {
    "scale": {
      "color": "independent"
    }
  },
  "config": {
    "view": {
      "stroke": "#e1d7ca"
    },
    "font": "Arial"
  }
}