{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Compound glyph matrix showing how well each state's public toilet network supports different road-trip traveller personas.",
  "title": {
    "text": "The same toilet network works differently for different travellers",
    "subtitle": "Circle size and colour show support score for each traveller persona in each state.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "data": {
    "url": "data_clean/persona_support.csv"
  },
  "transform": [
    {
      "calculate": "datum.Support_Score * 100",
      "as": "Support_Percent"
    },
    {
      "calculate": "format(datum.Support_Percent, '.0f') + '%'",
      "as": "Support_Label"
    }
  ],
  "vconcat": [
    {
      "width": 620,
      "height": 85,
      "transform": [
        {
          "aggregate": [
            {
              "op": "mean",
              "field": "Support_Score",
              "as": "Average_State_Support"
            }
          ],
          "groupby": [
            "State"
          ]
        },
        {
          "calculate": "format(datum.Average_State_Support * 100, '.0f') + '%'",
          "as": "Average_State_Label"
        }
      ],
      "layer": [
        {
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 3,
            "color": "#8b5e3c"
          },
          "encoding": {
            "x": {
              "field": "State",
              "type": "nominal",
              "sort": {
                "op": "mean",
                "field": "Average_State_Support",
                "order": "descending"
              },
              "title": null,
              "axis": {
                "labelFontSize": 11,
                "labelAngle": 0
              }
            },
            "y": {
              "field": "Average_State_Support",
              "type": "quantitative",
              "title": "Average support",
              "scale": {
                "domain": [0, 1]
              },
              "axis": {
                "format": "%",
                "labelFontSize": 10,
                "titleFontSize": 11
              }
            },
            "tooltip": [
              {
                "field": "State",
                "type": "nominal",
                "title": "State"
              },
              {
                "field": "Average_State_Support",
                "type": "quantitative",
                "title": "Average support",
                "format": ".1%"
              }
            ]
          }
        },
        {
          "mark": {
            "type": "text",
            "dy": -7,
            "fontSize": 10,
            "fontWeight": "bold",
            "color": "#4a3a2d"
          },
          "encoding": {
            "x": {
              "field": "State",
              "type": "nominal",
              "sort": {
                "op": "mean",
                "field": "Average_State_Support",
                "order": "descending"
              }
            },
            "y": {
              "field": "Average_State_Support",
              "type": "quantitative"
            },
            "text": {
              "field": "Average_State_Label",
              "type": "nominal"
            }
          }
        }
      ]
    },
    {
      "hconcat": [
        {
          "width": 620,
          "height": 285,
          "layer": [
            {
              "mark": {
                "type": "rect",
                "cornerRadius": 5,
                "stroke": "white",
                "strokeWidth": 1
              },
              "encoding": {
                "x": {
                  "field": "State",
                  "type": "nominal",
                  "sort": {
                    "op": "mean",
                    "field": "Support_Score",
                    "order": "descending"
                  },
                  "title": "State",
                  "axis": {
                    "labelAngle": 0,
                    "labelFontSize": 11,
                    "titleFontSize": 12
                  }
                },
                "y": {
                  "field": "Persona",
                  "type": "nominal",
                  "sort": [
                    "Night driver",
                    "Family traveller",
                    "Accessible traveller",
                    "Caravan traveller"
                  ],
                  "title": "Traveller persona",
                  "axis": {
                    "labelFontSize": 11,
                    "titleFontSize": 12
                  }
                },
                "color": {
                  "field": "Support_Score",
                  "type": "quantitative",
                  "title": "Support score",
                  "scale": {
                    "scheme": "oranges",
                    "domain": [0, 1]
                  },
                  "legend": {
                    "orient": "right",
                    "format": "%"
                  }
                },
                "tooltip": [
                  {
                    "field": "State",
                    "type": "nominal",
                    "title": "State"
                  },
                  {
                    "field": "Persona",
                    "type": "nominal",
                    "title": "Traveller persona"
                  },
                  {
                    "field": "Support_Score",
                    "type": "quantitative",
                    "title": "Support score",
                    "format": ".1%"
                  },
                  {
                    "field": "Support_Level",
                    "type": "nominal",
                    "title": "Support level"
                  }
                ]
              }
            },
            {
              "mark": {
                "type": "circle",
                "stroke": "white",
                "strokeWidth": 1.2,
                "opacity": 0.9
              },
              "encoding": {
                "x": {
                  "field": "State",
                  "type": "nominal",
                  "sort": {
                    "op": "mean",
                    "field": "Support_Score",
                    "order": "descending"
                  }
                },
                "y": {
                  "field": "Persona",
                  "type": "nominal",
                  "sort": [
                    "Night driver",
                    "Family traveller",
                    "Accessible traveller",
                    "Caravan traveller"
                  ]
                },
                "size": {
                  "field": "Support_Score",
                  "type": "quantitative",
                  "title": "Support score",
                  "scale": {
                    "range": [80, 900],
                    "domain": [0, 1]
                  },
                  "legend": null
                },
                "color": {
                  "field": "Support_Score",
                  "type": "quantitative",
                  "legend": null,
                  "scale": {
                    "scheme": "oranges",
                    "domain": [0, 1]
                  }
                },
                "tooltip": [
                  {
                    "field": "State",
                    "type": "nominal",
                    "title": "State"
                  },
                  {
                    "field": "Persona",
                    "type": "nominal",
                    "title": "Traveller persona"
                  },
                  {
                    "field": "Support_Score",
                    "type": "quantitative",
                    "title": "Support score",
                    "format": ".1%"
                  },
                  {
                    "field": "Support_Level",
                    "type": "nominal",
                    "title": "Support level"
                  }
                ]
              }
            },
            {
              "mark": {
                "type": "text",
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#3f3328"
              },
              "encoding": {
                "x": {
                  "field": "State",
                  "type": "nominal",
                  "sort": {
                    "op": "mean",
                    "field": "Support_Score",
                    "order": "descending"
                  }
                },
                "y": {
                  "field": "Persona",
                  "type": "nominal",
                  "sort": [
                    "Night driver",
                    "Family traveller",
                    "Accessible traveller",
                    "Caravan traveller"
                  ]
                },
                "text": {
                  "field": "Support_Label",
                  "type": "nominal"
                }
              }
            }
          ]
        },
        {
          "width": 150,
          "height": 285,
          "transform": [
            {
              "aggregate": [
                {
                  "op": "mean",
                  "field": "Support_Score",
                  "as": "Average_Persona_Support"
                }
              ],
              "groupby": [
                "Persona"
              ]
            },
            {
              "calculate": "format(datum.Average_Persona_Support * 100, '.0f') + '%'",
              "as": "Average_Persona_Label"
            }
          ],
          "layer": [
            {
              "mark": {
                "type": "bar",
                "cornerRadiusEnd": 3,
                "color": "#4f6f7f"
              },
              "encoding": {
                "y": {
                  "field": "Persona",
                  "type": "nominal",
                  "sort": [
                    "Night driver",
                    "Family traveller",
                    "Accessible traveller",
                    "Caravan traveller"
                  ],
                  "title": null,
                  "axis": {
                    "labels": false,
                    "ticks": false,
                    "domain": false
                  }
                },
                "x": {
                  "field": "Average_Persona_Support",
                  "type": "quantitative",
                  "title": "Persona avg.",
                  "scale": {
                    "domain": [0, 1]
                  },
                  "axis": {
                    "format": "%",
                    "labelFontSize": 10,
                    "titleFontSize": 11,
                    "grid": true
                  }
                },
                "tooltip": [
                  {
                    "field": "Persona",
                    "type": "nominal",
                    "title": "Traveller persona"
                  },
                  {
                    "field": "Average_Persona_Support",
                    "type": "quantitative",
                    "title": "Average support",
                    "format": ".1%"
                  }
                ]
              }
            },
            {
              "mark": {
                "type": "text",
                "align": "left",
                "baseline": "middle",
                "dx": 5,
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#2f2f2f"
              },
              "encoding": {
                "y": {
                  "field": "Persona",
                  "type": "nominal",
                  "sort": [
                    "Night driver",
                    "Family traveller",
                    "Accessible traveller",
                    "Caravan traveller"
                  ]
                },
                "x": {
                  "field": "Average_Persona_Support",
                  "type": "quantitative"
                },
                "text": {
                  "field": "Average_Persona_Label",
                  "type": "nominal"
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "resolve": {
    "scale": {
      "color": "independent",
      "size": "independent"
    }
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}