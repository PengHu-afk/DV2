{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Feature importance bar chart showing the weighted importance of five traveller-support features in the road-trip readiness score.",
  "title": {
    "text": "Which features matter most for road-trip readiness?",
    "subtitle": "Bars show the weight assigned to each feature in the custom readiness score.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "width": 420,
  "height": 330,
  "data": {
    "url": "data_clean/readiness_components_long.csv"
  },
  "transform": [
    {
      "filter": "datum.State != null && datum.State != '' && datum.State != 'NA'"
    },
    {
      "calculate": "datum.Component == 'Accessible' ? 'Accessible access' : datum.Component == '24-hour' ? '24-hour access' : datum.Component == 'Parking' ? 'Parking' : datum.Component == 'Baby change' ? 'Baby-change facilities' : datum.Component == 'Shower' ? 'Showers' : datum.Component",
      "as": "Component_Clean"
    },
    {
      "aggregate": [
        {
          "op": "max",
          "field": "Weight",
          "as": "Feature_Weight"
        },
        {
          "op": "mean",
          "field": "Rate",
          "as": "Average_Availability"
        }
      ],
      "groupby": [
        "Component_Clean"
      ]
    },
    {
      "calculate": "datum.Feature_Weight * 100",
      "as": "Weight_Percent"
    },
    {
      "calculate": "datum.Average_Availability * 100",
      "as": "Average_Availability_Percent"
    },
    {
      "calculate": "format(datum.Weight_Percent, '.0f') + '%'",
      "as": "Weight_Label"
    },
    {
      "calculate": "format(datum.Average_Availability_Percent, '.1f') + '%'",
      "as": "Availability_Label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4,
        "height": {
          "band": 0.58
        }
      },
      "encoding": {
        "y": {
          "field": "Component_Clean",
          "type": "nominal",
          "title": null,
          "sort": "-x",
          "axis": {
            "labelFontSize": 12
          }
        },
        "x": {
          "field": "Weight_Percent",
          "type": "quantitative",
          "title": "Feature weight in readiness score (%)",
          "scale": {
            "domain": [
              0,
              35
            ]
          },
          "axis": {
            "labelFontSize": 11,
            "titleFontSize": 12,
            "grid": true
          }
        },
        "color": {
          "field": "Component_Clean",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": [
              "Accessible access",
              "24-hour access",
              "Parking",
              "Baby-change facilities",
              "Showers"
            ],
            "range": [
              "#4f6f7f",
              "#6b4f3f",
              "#b77945",
              "#d9a65f",
              "#5f7f58"
            ]
          }
        },
        "tooltip": [
          {
            "field": "Component_Clean",
            "type": "nominal",
            "title": "Feature"
          },
          {
            "field": "Weight_Label",
            "type": "nominal",
            "title": "Readiness score weight"
          },
          {
            "field": "Availability_Label",
            "type": "nominal",
            "title": "Average availability across states"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 6,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#102a3d"
      },
      "encoding": {
        "y": {
          "field": "Component_Clean",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "Weight_Percent",
          "type": "quantitative"
        },
        "text": {
          "field": "Weight_Label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    }
  }
}