{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Line chart showing actual domestic travel demand by state across 2025 quarters.",
  "title": {
    "text": "Domestic travel demand by state across 2025",
    "subtitle": "The y-axis now shows actual travel volume rather than rank, making seasonal variation easier to see.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "width": 760,
  "height": 420,
  "data": {
    "url": "data_clean/tourism_rank_long.csv"
  },
  "transform": [
    {
      "filter": "isValid(datum.Trips_Million)"
    },
    {
      "calculate": "datum.Quarter_Order == 1 ? 'Mar' : datum.Quarter_Order == 2 ? 'Jun' : datum.Quarter_Order == 3 ? 'Sep' : datum.Quarter_Order == 4 ? 'Dec' : datum.Quarter",
      "as": "Quarter_Label"
    },
    {
      "calculate": "format(datum.Trips_Million, '.1f') + 'M'",
      "as": "Trips_Label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 3,
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "Quarter_Label",
          "type": "ordinal",
          "sort": ["Mar", "Jun", "Sep", "Dec"],
          "title": "2025 quarter",
          "axis": {
            "labelAngle": 0,
            "labelFontSize": 12,
            "titleFontSize": 12
          }
        },
        "y": {
          "field": "Trips_Million",
          "type": "quantitative",
          "title": "Domestic travel demand (million trips)",
          "scale": {
            "nice": true,
            "zero": false
          },
          "axis": {
            "labelFontSize": 12,
            "titleFontSize": 12,
            "grid": true
          }
        },
        "color": {
          "field": "State",
          "type": "nominal",
          "legend": null
        },
        "detail": {
          "field": "State",
          "type": "nominal"
        },
        "tooltip": [
          {
            "field": "State",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Quarter",
            "type": "nominal",
            "title": "Quarter"
          },
          {
            "field": "Trips_Million",
            "type": "quantitative",
            "title": "Domestic trips (M)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 95,
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": {
          "field": "Quarter_Label",
          "type": "ordinal",
          "sort": ["Mar", "Jun", "Sep", "Dec"]
        },
        "y": {
          "field": "Trips_Million",
          "type": "quantitative"
        },
        "color": {
          "field": "State",
          "type": "nominal",
          "legend": null
        },
        "tooltip": [
          {
            "field": "State",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Quarter",
            "type": "nominal",
            "title": "Quarter"
          },
          {
            "field": "Trips_Label",
            "type": "nominal",
            "title": "Trips"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Quarter_Order == 4"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 10,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "Quarter_Label",
          "type": "ordinal",
          "sort": ["Mar", "Jun", "Sep", "Dec"]
        },
        "y": {
          "field": "Trips_Million",
          "type": "quantitative"
        },
        "text": {
          "field": "State",
          "type": "nominal"
        },
        "color": {
          "field": "State",
          "type": "nominal",
          "legend": null
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    }
  }
}