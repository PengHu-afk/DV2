{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Quadrant chart comparing domestic travel demand with public toilet supply by Australian state.",
  "title": {
    "text": "Where does tourism demand outpace toilet supply?",
    "subtitle": "States in the upper-left area have higher travel demand but fewer public toilets.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "width": 760,
  "height": 430,
  "data": {
    "url": "data_clean/state_combined_summary.csv"
  },
  "transform": [
    {
      "filter": "isValid(datum.Toilet_Count) && isValid(datum.Total_Domestic_Trips) && isValid(datum.Trips_Per_Toilet)"
    },
    {
      "calculate": "datum.Total_Domestic_Trips / 1000",
      "as": "Trips_Million"
    },
    {
      "calculate": "datum.Roadtrip_Readiness_Score * 100",
      "as": "Readiness_Percent"
    },
    {
      "calculate": "format(datum.Trips_Million, '.1f') + 'M trips'",
      "as": "Trips_Label"
    },
    {
      "calculate": "format(datum.Trips_Per_Toilet, '.2f') + 'k trips per toilet'",
      "as": "Pressure_Label"
    },
    {
      "calculate": "format(datum.Readiness_Percent, '.1f') + '%'",
      "as": "Readiness_Label"
    }
  ],
  "layer": [
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "median",
              "field": "Toilet_Count",
              "as": "Median_Toilet_Count"
            }
          ]
        }
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [6, 5],
        "strokeWidth": 1.2,
        "color": "#8a8178"
      },
      "encoding": {
        "x": {
          "field": "Median_Toilet_Count",
          "type": "quantitative"
        }
      }
    },
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "median",
              "field": "Trips_Million",
              "as": "Median_Trips_Million"
            }
          ]
        }
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [6, 5],
        "strokeWidth": 1.2,
        "color": "#8a8178"
      },
      "encoding": {
        "y": {
          "field": "Median_Trips_Million",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 220,
        "opacity": 0.82,
        "stroke": "white",
        "strokeWidth": 1.4
      },
      "encoding": {
        "x": {
          "field": "Toilet_Count",
          "type": "quantitative",
          "title": "Public toilet supply (number of toilets)",
          "axis": {
            "grid": true,
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "y": {
          "field": "Trips_Million",
          "type": "quantitative",
          "title": "Domestic travel demand (million trips)",
          "axis": {
            "grid": true,
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "color": {
          "field": "Trips_Per_Toilet",
          "type": "quantitative",
          "title": "Pressure: trips per toilet",
          "scale": {
            "scheme": "oranges"
          },
          "legend": {
            "orient": "right"
          }
        },
        "tooltip": [
          {
            "field": "State_Full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Toilet_Count",
            "type": "quantitative",
            "title": "Public toilets",
            "format": ","
          },
          {
            "field": "Trips_Label",
            "type": "nominal",
            "title": "Domestic trips"
          },
          {
            "field": "Pressure_Label",
            "type": "nominal",
            "title": "Pressure"
          },
          {
            "field": "Readiness_Label",
            "type": "nominal",
            "title": "Readiness score"
          },
          {
            "field": "Priority_Category",
            "type": "nominal",
            "title": "Priority category"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#2f2f2f"
      },
      "encoding": {
        "x": {
          "field": "Toilet_Count",
          "type": "quantitative"
        },
        "y": {
          "field": "Trips_Million",
          "type": "quantitative"
        },
        "text": {
          "field": "State",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}