{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Final action-priority quadrant chart using simplified priority categories and fixed point size.",
  "title": {
    "text": "Target pressure points, not toilets everywhere",
    "subtitle": "Improvements should focus where travel pressure is high and traveller-support features are weaker.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "width": 620,
  "height": 420,
  "data": {
    "url": "data_clean/state_combined_summary.csv"
  },
  "transform": [
    {
      "filter": "isValid(datum.Trips_Per_Toilet) && isValid(datum.Roadtrip_Readiness_Score) && datum.State != null && datum.State != '' && datum.State != 'NA'"
    },
    {
      "calculate": "datum.Roadtrip_Readiness_Score * 100",
      "as": "Readiness_Percent"
    },
    {
      "calculate": "datum.Total_Domestic_Trips / 1000",
      "as": "Trips_Million"
    },
    {
      "calculate": "format(datum.Trips_Per_Toilet, '.2f') + 'k trips per toilet'",
      "as": "Pressure_Label"
    },
    {
      "calculate": "format(datum.Readiness_Percent, '.1f') + '%'",
      "as": "Readiness_Label"
    },
    {
      "calculate": "format(datum.Trips_Million, '.1f') + 'M trips'",
      "as": "Trips_Label"
    },
    {
      "joinaggregate": [
        {
          "op": "median",
          "field": "Trips_Per_Toilet",
          "as": "Median_Pressure"
        },
        {
          "op": "median",
          "field": "Readiness_Percent",
          "as": "Median_Readiness"
        }
      ]
    },
    {
      "calculate": "datum.Trips_Per_Toilet >= datum.Median_Pressure && datum.Readiness_Percent < datum.Median_Readiness ? 'Priority improvement area' : datum.Readiness_Percent < datum.Median_Readiness ? 'Improve specific facilities' : 'Maintain strong network'",
      "as": "Simple_Priority"
    },
    {
      "calculate": "datum.State == 'NSW' ? 10 : datum.State == 'VIC' ? 10 : datum.State == 'QLD' ? 10 : datum.State == 'ACT' ? 10 : 7",
      "as": "Label_DX"
    },
    {
      "calculate": "datum.State == 'NSW' ? -12 : datum.State == 'VIC' ? 12 : datum.State == 'QLD' ? -10 : datum.State == 'ACT' ? 12 : 0",
      "as": "Label_DY"
    }
  ],
  "layer": [
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "median",
              "field": "Trips_Per_Toilet",
              "as": "Median_Pressure"
            }
          ]
        }
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [6, 5],
        "strokeWidth": 1.3,
        "color": "#8a8178"
      },
      "encoding": {
        "x": {
          "field": "Median_Pressure",
          "type": "quantitative"
        }
      }
    },
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "median",
              "field": "Readiness_Percent",
              "as": "Median_Readiness"
            }
          ]
        }
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [6, 5],
        "strokeWidth": 1.3,
        "color": "#8a8178"
      },
      "encoding": {
        "y": {
          "field": "Median_Readiness",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 230,
        "opacity": 0.86,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "Trips_Per_Toilet",
          "type": "quantitative",
          "title": "Travel pressure: thousand trips per toilet",
          "axis": {
            "grid": true,
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "y": {
          "field": "Readiness_Percent",
          "type": "quantitative",
          "title": "Road-trip readiness score (%)",
          "scale": {
            "zero": false
          },
          "axis": {
            "grid": true,
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "color": {
          "field": "Simple_Priority",
          "type": "nominal",
          "title": "Priority category",
          "scale": {
            "domain": [
              "Maintain strong network",
              "Improve specific facilities",
              "Priority improvement area"
            ],
            "range": [
              "#8a8178",
              "#d9a65f",
              "#b24a3b"
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "titleAnchor": "start",
            "labelFontSize": 10,
            "titleFontSize": 11
          }
        },
        "tooltip": [
          {
            "field": "State_Full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Pressure_Label",
            "type": "nominal",
            "title": "Travel pressure"
          },
          {
            "field": "Readiness_Label",
            "type": "nominal",
            "title": "Readiness score"
          },
          {
            "field": "Toilet_Count",
            "type": "quantitative",
            "title": "Public toilets",
            "format": ","
          },
          {
            "field": "Trips_Label",
            "type": "nominal",
            "title": "Domestic trips"
          },
          {
            "field": "Simple_Priority",
            "type": "nominal",
            "title": "Simplified priority"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "fontSize": 10,
        "fontWeight": "bold",
        "color": "#2f2f2f"
      },
      "encoding": {
        "x": {
          "field": "Trips_Per_Toilet",
          "type": "quantitative"
        },
        "y": {
          "field": "Readiness_Percent",
          "type": "quantitative"
        },
        "dx": {
          "field": "Label_DX"
        },
        "dy": {
          "field": "Label_DY"
        },
        "text": {
          "field": "State",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    },
    "legend": {
      "labelFontSize": 10,
      "titleFontSize": 11
    }
  }
}