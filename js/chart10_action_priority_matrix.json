{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Decision matrix showing where public toilet access improvements should be prioritised based on travel pressure and road-trip readiness.",
  "title": {
    "text": "Where should public toilet improvements be prioritised?",
    "subtitle": "The most important areas are where high travel pressure meets weaker toilet readiness.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "width": 760,
  "height": 450,
  "data": {
    "url": "data_clean/state_combined_summary.csv"
  },
  "transform": [
    {
      "filter": "isValid(datum.Trips_Per_Toilet) && isValid(datum.Roadtrip_Readiness_Score)"
    },
    {
      "calculate": "datum.Roadtrip_Readiness_Score * 100",
      "as": "Readiness_Percent"
    },
    {
      "calculate": "datum.Total_Domestic_Trips / 1000",
      "as": "Trips_Million"
    },
    {
      "calculate": "format(datum.Trips_Per_Toilet, '.2f') + 'k trips per toilet'",
      "as": "Pressure_Label"
    },
    {
      "calculate": "format(datum.Readiness_Percent, '.1f') + '%'",
      "as": "Readiness_Label"
    },
    {
      "calculate": "format(datum.Trips_Million, '.1f') + 'M trips'",
      "as": "Trips_Label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#8a6f55",
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "value": 20
        },
        "y": {
          "value": 22
        },
        "text": {
          "value": "Lower pressure\nstronger readiness"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "top",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#8a6f55",
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "value": 735
        },
        "y": {
          "value": 22
        },
        "text": {
          "value": "Busy but prepared"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "bottom",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#8a6f55",
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "value": 735
        },
        "y": {
          "value": 420
        },
        "text": {
          "value": "Priority improvement area"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#8a6f55",
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "value": 20
        },
        "y": {
          "value": 420
        },
        "text": {
          "value": "Lower demand\npossible access gap"
        }
      }
    },
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "median",
              "field": "Trips_Per_Toilet",
              "as": "Median_Pressure"
            }
          ]
        }
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [6, 5],
        "strokeWidth": 1.3,
        "color": "#8a8178"
      },
      "encoding": {
        "x": {
          "field": "Median_Pressure",
          "type": "quantitative"
        }
      }
    },
    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "median",
              "field": "Readiness_Percent",
              "as": "Median_Readiness"
            }
          ]
        }
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [6, 5],
        "strokeWidth": 1.3,
        "color": "#8a8178"
      },
      "encoding": {
        "y": {
          "field": "Median_Readiness",
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "opacity": 0.86,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "Trips_Per_Toilet",
          "type": "quantitative",
          "title": "Travel pressure (thousand trips per toilet)",
          "axis": {
            "grid": true,
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "y": {
          "field": "Readiness_Percent",
          "type": "quantitative",
          "title": "Road-trip readiness score (%)",
          "scale": {
            "zero": false
          },
          "axis": {
            "grid": true,
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "size": {
          "field": "Toilet_Count",
          "type": "quantitative",
          "title": "Public toilets",
          "scale": {
            "range": [150, 1100]
          },
          "legend": {
            "orient": "right"
          }
        },
        "color": {
          "field": "Priority_Category",
          "type": "nominal",
          "title": "Priority category",
          "scale": {
            "domain": [
              "High demand, weak readiness",
              "Improve night access",
              "Improve accessibility",
              "Improve family support",
              "Improve traveller facilities",
              "Maintain strong network"
            ],
            "range": [
              "#b24a3b",
              "#8b5e3c",
              "#4f6f7f",
              "#d9a65f",
              "#5f7f58",
              "#8a8178"
            ]
          },
          "legend": {
            "orient": "right"
          }
        },
        "tooltip": [
          {
            "field": "State_Full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Pressure_Label",
            "type": "nominal",
            "title": "Travel pressure"
          },
          {
            "field": "Readiness_Label",
            "type": "nominal",
            "title": "Readiness score"
          },
          {
            "field": "Toilet_Count",
            "type": "quantitative",
            "title": "Public toilets",
            "format": ","
          },
          {
            "field": "Trips_Label",
            "type": "nominal",
            "title": "Domestic trips"
          },
          {
            "field": "Priority_Category",
            "type": "nominal",
            "title": "Suggested priority"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#2f2f2f"
      },
      "encoding": {
        "x": {
          "field": "Trips_Per_Toilet",
          "type": "quantitative"
        },
        "y": {
          "field": "Readiness_Percent",
          "type": "quantitative"
        },
        "text": {
          "field": "State",
          "type": "nominal"
        },
        "tooltip": [
          {
            "field": "State_Full",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Priority_Category",
            "type": "nominal",
            "title": "Suggested priority"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}