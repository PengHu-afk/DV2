{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bin map showing relative toilet supply, using state-level domestic travel demand as the denominator proxy.",
  "title": {
    "text": "Where is toilet supply relatively thin?",
    "subtitle": "Grid colours now reflect relative toilet supply per million domestic trips, rather than raw toilet counts.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "width": 760,
  "height": 430,
  "data": {
    "url": "data_clean/toilet_clean.csv"
  },
  "transform": [
    {
      "filter": "isValid(datum.Longitude) && isValid(datum.Latitude)"
    },
    {
      "filter": "datum.Longitude >= 112 && datum.Longitude <= 154 && datum.Latitude >= -44 && datum.Latitude <= -10"
    },
    {
      "lookup": "State",
      "from": {
        "data": {
          "url": "data_clean/state_combined_summary.csv"
        },
        "key": "State",
        "fields": ["Total_Domestic_Trips"]
      }
    },
    {
      "filter": "isValid(datum.Total_Domestic_Trips)"
    },
    {
      "calculate": "datum.Total_Domestic_Trips / 1000",
      "as": "Demand_Million"
    },
    {
      "bin": {
        "step": 0.75
      },
      "field": "Longitude",
      "as": ["lon_bin", "lon_bin_end"]
    },
    {
      "bin": {
        "step": 0.75
      },
      "field": "Latitude",
      "as": ["lat_bin", "lat_bin_end"]
    },
    {
      "aggregate": [
        {
          "op": "count",
          "field": "FacilityID",
          "as": "Toilet_Count"
        },
        {
          "op": "mean",
          "field": "Demand_Million",
          "as": "Demand_Million"
        }
      ],
      "groupby": ["lon_bin", "lon_bin_end", "lat_bin", "lat_bin_end"]
    },
    {
      "calculate": "datum.Toilet_Count / datum.Demand_Million",
      "as": "Relative_Supply"
    },
    {
      "calculate": "format(datum.Relative_Supply, '.2f')",
      "as": "Relative_Supply_Label"
    }
  ],
  "mark": {
    "type": "rect",
    "stroke": "#faf7f2",
    "strokeWidth": 0.4
  },
  "encoding": {
    "x": {
      "field": "lon_bin",
      "type": "quantitative",
      "bin": "binned",
      "title": "Longitude",
      "axis": {
        "labelFontSize": 11,
        "titleFontSize": 12,
        "grid": false
      }
    },
    "x2": {
      "field": "lon_bin_end"
    },
    "y": {
      "field": "lat_bin",
      "type": "quantitative",
      "bin": "binned",
      "title": "Latitude",
      "axis": {
        "labelFontSize": 11,
        "titleFontSize": 12,
        "grid": false
      }
    },
    "y2": {
      "field": "lat_bin_end"
    },
    "color": {
      "field": "Relative_Supply",
      "type": "quantitative",
      "title": "Relative supply (toilets per 1M trips, darker = lower)",
      "scale": {
        "scheme": "oranges",
        "reverse": true
      },
      "legend": {
        "orient": "right"
      }
    },
    "tooltip": [
      {
        "field": "Toilet_Count",
        "type": "quantitative",
        "title": "Toilets in grid"
      },
      {
        "field": "Demand_Million",
        "type": "quantitative",
        "title": "Travel demand proxy (M trips)",
        "format": ".2f"
      },
      {
        "field": "Relative_Supply_Label",
        "type": "nominal",
        "title": "Relative supply"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    }
  }
}