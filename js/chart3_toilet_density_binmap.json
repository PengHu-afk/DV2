{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "A bin map showing the spatial density of public toilets across Australia using longitude and latitude bins.",
  "title": {
    "text": "Public toilets cluster around cities and travel corridors",
    "subtitle": "Each grid cell counts how many public toilets fall within that longitude-latitude area.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "width": 760,
  "height": 430,
  "data": {
    "url": "data_clean/toilet_clean.csv"
  },
  "transform": [
    {
      "filter": "isValid(datum.Longitude) && isValid(datum.Latitude)"
    },
    {
      "filter": "datum.Longitude >= 112 && datum.Longitude <= 154 && datum.Latitude >= -44 && datum.Latitude <= -10"
    }
  ],
  "mark": {
    "type": "rect",
    "stroke": "#faf7f2",
    "strokeWidth": 0.4
  },
  "encoding": {
    "x": {
      "field": "Longitude",
      "type": "quantitative",
      "bin": {
        "step": 0.75
      },
      "title": "Longitude",
      "axis": {
        "labelFontSize": 11,
        "titleFontSize": 12,
        "grid": false
      }
    },
    "y": {
      "field": "Latitude",
      "type": "quantitative",
      "bin": {
        "step": 0.75
      },
      "title": "Latitude",
      "scale": {
        "reverse": false
      },
      "axis": {
        "labelFontSize": 11,
        "titleFontSize": 12,
        "grid": false
      }
    },
    "color": {
      "aggregate": "count",
      "field": "FacilityID",
      "type": "quantitative",
      "title": "Toilets per grid cell",
      "scale": {
        "scheme": "oranges",
        "type": "sqrt"
      },
      "legend": {
        "orient": "right"
      }
    },
    "tooltip": [
      {
        "aggregate": "count",
        "field": "FacilityID",
        "type": "quantitative",
        "title": "Toilets in cell"
      },
      {
        "field": "Longitude",
        "type": "quantitative",
        "bin": {
          "step": 0.75
        },
        "title": "Longitude bin"
      },
      {
        "field": "Latitude",
        "type": "quantitative",
        "bin": {
          "step": 0.75
        },
        "title": "Latitude bin"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    }
  }
}