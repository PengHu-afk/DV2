{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Compound heatmap showing how cleaned facility types support road-trip traveller needs, with duplicate categories merged and labels only shown for high-value cells.",
  "title": {
    "text": "Which facility types actually support road-trip needs?",
    "subtitle": "Duplicate facility names are merged, and labels highlight only strong support cells above 60%.",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13
  },
  "data": {
    "url": "data_clean/facility_need_matrix.csv"
  },
  "transform": [
    {
      "calculate": "lower(trim(datum.FacilityType)) == 'park or reserve' ? 'Park or reserve' : datum.FacilityType",
      "as": "FacilityType_Clean"
    },
    {
      "calculate": "datum.Traveller_Need == 'Baby_Change' ? 'Baby change' : datum.Traveller_Need == 'Dump_Point' ? 'Dump point' : datum.Traveller_Need == 'Drinking_Water' ? 'Drinking water' : datum.Traveller_Need == 'TwentyFour_Hour' ? '24-hour access' : datum.Traveller_Need",
      "as": "Traveller_Need_Clean"
    },
    {
      "calculate": "datum.Availability_Rate * datum.Total_Count",
      "as": "Available_Estimate"
    },
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "Available_Estimate",
          "as": "Available_Total"
        },
        {
          "op": "sum",
          "field": "Total_Count",
          "as": "Total_Count_Clean"
        }
      ],
      "groupby": [
        "FacilityType_Clean",
        "Traveller_Need_Clean"
      ]
    },
    {
      "calculate": "datum.Available_Total / datum.Total_Count_Clean",
      "as": "Availability_Rate_Clean"
    },
    {
      "filter": "datum.Total_Count_Clean >= 30"
    },
    {
      "calculate": "datum.Availability_Rate_Clean >= 0.6 ? format(datum.Availability_Rate_Clean, '.0%') : ''",
      "as": "Important_Label"
    },
    {
      "calculate": "format(datum.Availability_Rate_Clean, '.1%')",
      "as": "Availability_Tooltip_Label"
    }
  ],
  "vconcat": [
    {
      "width": 540,
      "height": 35,
      "data": {
        "values": [
          {
            "note": "Rest areas and camping grounds provide stronger road-trip support than many general facility types."
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#7a5d45"
      },
      "encoding": {
        "x": {
          "value": 0
        },
        "y": {
          "value": 18
        },
        "text": {
          "field": "note",
          "type": "nominal"
        }
      }
    },
    {
      "width": 540,
      "height": 80,
      "transform": [
        {
          "aggregate": [
            {
              "op": "mean",
              "field": "Availability_Rate_Clean",
              "as": "Average_Availability"
            }
          ],
          "groupby": [
            "Traveller_Need_Clean"
          ]
        },
        {
          "calculate": "format(datum.Average_Availability, '.0%')",
          "as": "Average_Label"
        }
      ],
      "layer": [
        {
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 3,
            "color": "#b77945"
          },
          "encoding": {
            "x": {
              "field": "Traveller_Need_Clean",
              "type": "nominal",
              "sort": [
                "Accessible",
                "Baby change",
                "Parking",
                "Shower",
                "Dump point",
                "Drinking water",
                "24-hour access"
              ],
              "title": null,
              "axis": {
                "labelAngle": -25,
                "labelFontSize": 10
              }
            },
            "y": {
              "field": "Average_Availability",
              "type": "quantitative",
              "title": "Average availability",
              "scale": {
                "domain": [
                  0,
                  1
                ]
              },
              "axis": {
                "format": "%",
                "labelFontSize": 10,
                "titleFontSize": 11
              }
            },
            "tooltip": [
              {
                "field": "Traveller_Need_Clean",
                "type": "nominal",
                "title": "Traveller need"
              },
              {
                "field": "Average_Availability",
                "type": "quantitative",
                "title": "Average availability",
                "format": ".1%"
              }
            ]
          }
        },
        {
          "mark": {
            "type": "text",
            "dy": -6,
            "fontSize": 10,
            "fontWeight": "bold",
            "color": "#4a3a2d"
          },
          "encoding": {
            "x": {
              "field": "Traveller_Need_Clean",
              "type": "nominal",
              "sort": [
                "Accessible",
                "Baby change",
                "Parking",
                "Shower",
                "Dump point",
                "Drinking water",
                "24-hour access"
              ]
            },
            "y": {
              "field": "Average_Availability",
              "type": "quantitative"
            },
            "text": {
              "field": "Average_Label",
              "type": "nominal"
            }
          }
        }
      ]
    },
    {
      "hconcat": [
        {
          "width": 540,
          "height": 390,
          "layer": [
            {
              "mark": {
                "type": "rect",
                "stroke": "white",
                "strokeWidth": 1
              },
              "encoding": {
                "x": {
                  "field": "Traveller_Need_Clean",
                  "type": "nominal",
                  "sort": [
                    "Accessible",
                    "Baby change",
                    "Parking",
                    "Shower",
                    "Dump point",
                    "Drinking water",
                    "24-hour access"
                  ],
                  "title": "Traveller need",
                  "axis": {
                    "labelAngle": -25,
                    "labelFontSize": 10,
                    "titleFontSize": 12
                  }
                },
                "y": {
                  "field": "FacilityType_Clean",
                  "type": "nominal",
                  "sort": {
                    "op": "max",
                    "field": "Total_Count_Clean",
                    "order": "descending"
                  },
                  "title": "Facility type",
                  "axis": {
                    "labelFontSize": 10,
                    "titleFontSize": 12
                  }
                },
                "color": {
                  "field": "Availability_Rate_Clean",
                  "type": "quantitative",
                  "title": "Availability rate",
                  "scale": {
                    "scheme": "oranges",
                    "domain": [
                      0,
                      1
                    ]
                  },
                  "legend": {
                    "orient": "right",
                    "format": "%"
                  }
                },
                "tooltip": [
                  {
                    "field": "FacilityType_Clean",
                    "type": "nominal",
                    "title": "Facility type"
                  },
                  {
                    "field": "Traveller_Need_Clean",
                    "type": "nominal",
                    "title": "Traveller need"
                  },
                  {
                    "field": "Availability_Tooltip_Label",
                    "type": "nominal",
                    "title": "Availability rate"
                  },
                  {
                    "field": "Total_Count_Clean",
                    "type": "quantitative",
                    "title": "Number of toilets in this type",
                    "format": ","
                  }
                ]
              }
            },
            {
              "mark": {
                "type": "text",
                "fontSize": 9,
                "fontWeight": "bold",
                "color": "#3f3328"
              },
              "encoding": {
                "x": {
                  "field": "Traveller_Need_Clean",
                  "type": "nominal",
                  "sort": [
                    "Accessible",
                    "Baby change",
                    "Parking",
                    "Shower",
                    "Dump point",
                    "Drinking water",
                    "24-hour access"
                  ]
                },
                "y": {
                  "field": "FacilityType_Clean",
                  "type": "nominal",
                  "sort": {
                    "op": "max",
                    "field": "Total_Count_Clean",
                    "order": "descending"
                  }
                },
                "text": {
                  "field": "Important_Label",
                  "type": "nominal"
                }
              }
            }
          ]
        },
        {
          "width": 110,
          "height": 390,
          "transform": [
            {
              "aggregate": [
                {
                  "op": "max",
                  "field": "Total_Count_Clean",
                  "as": "Facility_Count"
                }
              ],
              "groupby": [
                "FacilityType_Clean"
              ]
            }
          ],
          "layer": [
            {
              "mark": {
                "type": "bar",
                "cornerRadiusEnd": 3,
                "color": "#6b4f3f"
              },
              "encoding": {
                "y": {
                  "field": "FacilityType_Clean",
                  "type": "nominal",
                  "sort": {
                    "op": "max",
                    "field": "Facility_Count",
                    "order": "descending"
                  },
                  "title": null,
                  "axis": {
                    "labels": false,
                    "ticks": false,
                    "domain": false
                  }
                },
                "x": {
                  "field": "Facility_Count",
                  "type": "quantitative",
                  "title": "Total count",
                  "scale": {
                    "type": "sqrt"
                  },
                  "axis": {
                    "labelFontSize": 10,
                    "titleFontSize": 11,
                    "grid": true
                  }
                },
                "tooltip": [
                  {
                    "field": "FacilityType_Clean",
                    "type": "nominal",
                    "title": "Facility type"
                  },
                  {
                    "field": "Facility_Count",
                    "type": "quantitative",
                    "title": "Number of toilets",
                    "format": ","
                  }
                ]
              }
            },
            {
              "mark": {
                "type": "text",
                "align": "left",
                "baseline": "middle",
                "dx": 4,
                "fontSize": 9,
                "color": "#4a3a2d"
              },
              "encoding": {
                "y": {
                  "field": "FacilityType_Clean",
                  "type": "nominal",
                  "sort": {
                    "op": "max",
                    "field": "Facility_Count",
                    "order": "descending"
                  }
                },
                "x": {
                  "field": "Facility_Count",
                  "type": "quantitative",
                  "scale": {
                    "type": "sqrt"
                  }
                },
                "text": {
                  "field": "Facility_Count",
                  "type": "quantitative",
                  "format": ","
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "resolve": {
    "scale": {
      "color": "independent"
    }
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}